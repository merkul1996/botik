# Telegram
BOT_TOKEN=
WEBAPP_URL=https://your-public-domain.com
BOT_USERNAME=

# Main AI (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Fantasy 18+ AI (separate uncensored provider, optional)
# Falls back to OPENAI_* if not set
FANTASY_API_KEY=
FANTASY_BASE_URL=
FANTASY_MODEL=

# Image generation (fal.ai)
FAL_API_KEY=

# Database (ОБЯЗАТЕЛЬНО для продакшена — без него данные теряются при рестарте)
# Локально: postgresql://user:pass@localhost:5432/botik
# Docker:   postgresql://botik:botik@postgres:5432/botik
DATABASE_URL=postgresql://botik:botik@localhost:5432/botik
DATABASE_SSL=false

# Redis (для rate limiting; без ioredis — fallback на memory)
# Docker: redis://redis:6379
REDIS_URL=

# Admin (comma-separated Telegram user IDs)
ADMIN_USER_IDS=

# Limits
FREE_DAILY_LIMIT=25
PRO_DAILY_LIMIT=300

# Environment
NODE_ENV=development
PORT=3000
